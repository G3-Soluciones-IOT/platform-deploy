# ==================================================
# JameoFit - Local Environment Example
# ==================================================
# Copy this file as:
#
#   cp env/local.env.example env/local.env
#
# Do not commit env/local.env.
# This file contains local-only values.

# ==================================================
# Platform services
# ==================================================

CONFIG_SERVICE_SPRING_PROFILES_ACTIVE=native
CONFIG_SERVER_URI=http://config-service:8888
PUBLIC_API_BASE_URL=http://localhost:8080
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
LOCAL_POSTGRES_HOST=host.docker.internal
LOCAL_POSTGRES_PORT=5432
LOCAL_MONGO_HOST=host.docker.internal
LOCAL_MONGO_PORT=27017
LOCAL_HIKARI_MAXIMUM_POOL_SIZE=4
LOCAL_HIKARI_MINIMUM_IDLE=0
LOCAL_HIKARI_CONNECTION_TIMEOUT_MS=20000
LOCAL_HIKARI_IDLE_TIMEOUT_MS=30000

AUTH0_ISSUER_URI=https://auth0.local/
AUTH0_AUDIENCE=jameofit-api
LEGACY_JWT_ENABLED=true
LEGACY_JWKS_ENABLED=true
LEGACY_JWT_ISSUER=iam-service
LEGACY_JWT_JWK_SET_URI=http://iam-service:8081/api/v1/jwks/.well-known/jwks.json

CONFIG_SERVICE_HOST_PORT=8888
EUREKA_SERVICE_HOST_PORT=8761
GATEWAY_SERVICE_HOST_PORT=8080

# ==================================================
# Application service ports
# ==================================================
# These ports must match the values served by config-service.

IAM_SERVICE_HOST_PORT=8081
GOALS_SERVICE_HOST_PORT=8083
MEAL_PLANS_SERVICE_HOST_PORT=8084
PAYMENTS_SERVICE_HOST_PORT=8092
NUTRITIONIST_SERVICE_HOST_PORT=8085
PROFILES_SERVICE_HOST_PORT=8086
RECIPES_SERVICE_HOST_PORT=8087
TRACKING_SERVICE_HOST_PORT=8089
IOT_SERVICE_HOST_PORT=8093
NUTRITION_AI_SERVICE_HOST_PORT=8091
COMMUNICATION_SERVICE_HOST_PORT=8090

# ==================================================
# iam-service database
# ==================================================

IAM_SERVICE_DB_NAME=iam_db
IAM_SERVICE_DB_USER=postgres
IAM_SERVICE_DB_PASSWORD=password

# ==================================================
# goals-service database
# ==================================================

GOALS_SERVICE_DB_NAME=goals_db
GOALS_SERVICE_DB_USER=postgres
GOALS_SERVICE_DB_PASSWORD=password

# ==================================================
# meal-plans-service database
# ==================================================

MEAL_PLANS_SERVICE_DB_NAME=meal_plans_db
MEAL_PLANS_SERVICE_DB_USER=postgres
MEAL_PLANS_SERVICE_DB_PASSWORD=password

# ==================================================
# payments-service database
# ==================================================

PAYMENTS_SERVICE_DB_NAME=payments_db
PAYMENTS_SERVICE_DB_USER=postgres
PAYMENTS_SERVICE_DB_PASSWORD=password
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ==================================================
# nutritionist-service database
# ==================================================

NUTRITIONIST_SERVICE_DB_NAME=nutritionist_db
NUTRITIONIST_SERVICE_DB_USER=postgres
NUTRITIONIST_SERVICE_DB_PASSWORD=password

# ==================================================
# profiles-service database
# ==================================================

PROFILES_SERVICE_DB_NAME=profiles_db
PROFILES_SERVICE_DB_USER=postgres
PROFILES_SERVICE_DB_PASSWORD=password

# ==================================================
# recipes-service database
# ==================================================

RECIPES_SERVICE_DB_NAME=recipes_db
RECIPES_SERVICE_DB_USER=postgres
RECIPES_SERVICE_DB_PASSWORD=password

# ==================================================
# tracking-service database
# ==================================================

TRACKING_SERVICE_DB_NAME=tracking_db
TRACKING_SERVICE_DB_USER=postgres
TRACKING_SERVICE_DB_PASSWORD=password

# ==================================================
# iot-service database
# ==================================================

IOT_SERVICE_DB_NAME=iot_db
IOT_SERVICE_DB_USER=postgres
IOT_SERVICE_DB_PASSWORD=password
IOT_API_KEY_SALT=12
IOT_DEVICE_MAX_PER_USER=5

# ==================================================
# nutrition-ai-service database and runtime
# ==================================================

NUTRITION_AI_DB_NAME=nutrition_ai_db
NUTRITION_AI_DB_USER=postgres
NUTRITION_AI_DB_PASSWORD=password
GCP_PROJECT_ID=local-jameofit
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
NUTRITION_AI_INTERNAL_TOKEN=internal-service-secret-key
INTERNAL_SERVICE_SECRET=internal-service-secret-key

# ==================================================
# communication-service MongoDB
# ==================================================

COMMUNICATION_SERVICE_MONGO_HOST_PORT=27017
COMMUNICATION_SERVICE_MONGO_DATABASE=communication_db
COMMUNICATION_SERVICE_MONGO_USER=communication_service
COMMUNICATION_SERVICE_MONGO_PASSWORD=password
COMMUNICATION_SERVICE_MONGO_AUTH_DB=admin
