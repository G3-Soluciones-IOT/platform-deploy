# ==================================================
# JameoFit - GCP Environment Example
# ==================================================
# `scripts/gcp-load-secrets.sh` generates env/gcp.env on the VM.
# Do not commit env/gcp.env or put credentials in this example.

# ---------- GCP / Artifact Registry ----------
GCP_PROJECT_ID=jameofit
GCP_REGION=southamerica-west1
GAR_REPOSITORY=jameofit-docker
# Use the immutable sha-<7-character-commit> tag emitted by each service CD workflow.
# For incremental updates, prefer:
#   scripts/gcp-deploy-service.sh <service-name> sha-xxxxxxx
# For dev/staging tag discovery, use:
#   scripts/gcp-refresh-image-tags.sh <service-name>
CONFIG_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_CONFIG_COMMIT
EUREKA_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_EUREKA_COMMIT
IAM_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_IAM_COMMIT
GATEWAY_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_GATEWAY_COMMIT
GOALS_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_GOALS_COMMIT
MEAL_PLANS_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_MEAL_PLANS_COMMIT
PAYMENTS_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_PAYMENTS_COMMIT
NUTRITIONIST_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_NUTRITIONIST_COMMIT
PROFILES_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_PROFILES_COMMIT
RECIPES_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_RECIPES_COMMIT
TRACKING_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_TRACKING_COMMIT
IOT_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_IOT_COMMIT
NUTRITION_AI_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_NUTRITION_AI_COMMIT
# Required only with COMPOSE_PROFILES=communication.
# COMMUNICATION_SERVICE_IMAGE_TAG=sha-REPLACE_WITH_COMMUNICATION_COMMIT

# ---------- Spring ----------
SPRING_PROFILES_ACTIVE=gcp
CONFIG_SERVICE_SPRING_PROFILES_ACTIVE=native
SPRING_FLYWAY_ENABLED=true
# Keep true only for the first Flyway adoption against databases that already
# have Hibernate-created tables. Set to false after flyway_schema_history exists.
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true

# ---------- Ports ----------
CONFIG_SERVICE_PORT=8888
EUREKA_SERVICE_PORT=8761
GATEWAY_SERVICE_PORT=8080
# Keep the VM private; set this only to an address reachable by its approved
# internal load balancer or proxy.
GATEWAY_BIND_ADDRESS=0.0.0.0

# ---------- Config Server ----------
CONFIG_SERVER_URI=http://config-service:8888

# ---------- Auth0 / Legacy JWT ----------
# AUTH0_ISSUER_URI must include the trailing slash, for example:
# https://your-tenant.us.auth0.com/
AUTH0_ISSUER_URI=https://REPLACE_WITH_AUTH0_DOMAIN/
AUTH0_AUDIENCE=REPLACE_WITH_AUTH0_API_IDENTIFIER
LEGACY_JWT_ENABLED=true
LEGACY_JWKS_ENABLED=true
LEGACY_JWT_ISSUER=iam-service
LEGACY_JWT_JWK_SET_URI=http://iam-service:8081/api/v1/jwks/.well-known/jwks.json

# ---------- Eureka ----------
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-service:8761/eureka/

# ---------- Cloud SQL PostgreSQL ----------
# Generated only in env/gcp.env by scripts/gcp-load-secrets.sh.
# IAM: jameofit-iam-db-url, jameofit-iam-db-username, jameofit-iam-db-password
# Goals: jameofit-goals-db-url, jameofit-goals-db-username, jameofit-goals-db-password
# Meal Plans: jameofit-meal-plans-db-url, jameofit-meal-plans-db-username, jameofit-meal-plans-db-password
# Payments: jameofit-payments-db-url, jameofit-payments-db-username, jameofit-payments-db-password
# Nutritionist: jameofit-nutritionist-db-url, jameofit-nutritionist-db-username, jameofit-nutritionist-db-password
# Profiles: jameofit-profiles-db-url, jameofit-profiles-db-username, jameofit-profiles-db-password
# Recipes: jameofit-recipes-db-url, jameofit-recipes-db-username, jameofit-recipes-db-password
# Tracking: jameofit-tracking-db-url, jameofit-tracking-db-username, jameofit-tracking-db-password
# IoT: jameofit-iot-db-url, jameofit-iot-db-username, jameofit-iot-db-password
# Nutrition AI: jameofit-nutrition-ai-db-url, jameofit-nutrition-ai-db-username, jameofit-nutrition-ai-db-password
# Legacy jameofit-db-* secrets are not used by the GCP deployment.

# ---------- Nutrition AI ----------
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
NUTRITION_AI_INTERNAL_TOKEN=internal-service-secret-key
INTERNAL_SERVICE_SECRET=internal-service-secret-key

# ---------- Payments ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- Communication MongoDB ----------
# communication-service is excluded from the default deployment.
# To enable it later, pass COMMUNICATION_MONGODB_SECRET_ID to gcp-load-secrets.sh
# and set COMPOSE_PROFILES=communication when running gcp-up.sh.
